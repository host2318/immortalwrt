CONFIG_PACKAGE_luci-proto-wireguard=y

# crypto
CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_GCM=y
CONFIG_CRYPTO_LIB_AES=y
CONFIG_CRYPTO_SIMD=y

