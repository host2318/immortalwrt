CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=y

# ================= UI =================
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ================= 基础网络 / 转发 =================
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-nft-fullcone=y

CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y

# ================= WireGuard =================
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-proto-wireguard=y

CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=y
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y

CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_GCM=y
CONFIG_CRYPTO_LIB_AES=y
CONFIG_CRYPTO_SIMD=y

# ================= OpenVPN =================
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_PACKAGE_openvpn-easy-rsa=y
CONFIG_PACKAGE_luci-app-openvpn-server=y

# 🔧 必备（修复 tun 相关问题）
CONFIG_PACKAGE_kmod-tun=y

# ================= DDNS / ACME =================
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-services=y
CONFIG_PACKAGE_ddns-scripts-dnspod=y

CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_acme=y

# ================= Passwall2（sing-box 主栈）=================
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_socat=y

CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_luci-app-passwall2_Basic_Core_SingBox=y

# ❌ 禁用其他核心
CONFIG_PACKAGE_luci-app-passwall2_Basic_Core_All=n
CONFIG_PACKAGE_luci-app-passwall2_Basic_Core_Xray=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray=n

CONFIG_PACKAGE_shadowsocks-libev=n
CONFIG_PACKAGE_shadowsocksr-libev=n
CONFIG_PACKAGE_shadowsocks-rust=n
CONFIG_PACKAGE_simple-obfs=n
CONFIG_PACKAGE_v2ray-plugin=n

CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Client=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Server=n

# ================= NSS（性能核心）=================
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-netlink=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-vlan=y
CONFIG_PACKAGE_kmod-qca-nss-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-crypto=y

# ================= Firewall =================
CONFIG_PACKAGE_firewall4=y

# ================= EasyTier =================
CONFIG_PACKAGE_easytier=y
CONFIG_PACKAGE_luci-app-easytier=y

# ================= Samba4（文件服务）=================
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-utils=y
CONFIG_PACKAGE_luci-app-samba4=y

# ================= 存储 / 管理工具 =================
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y

# ================= 基础工具 =================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_vim=y
CONFIG_PACKAGE_curl=y

# ================= SSH =================
CONFIG_PACKAGE_openssh-sftp-server=y

# ================= 关键架构说明 =================
# ✔ 数据面：NSS hardware offload（主路径）
# ✔ 转发：nft fullcone + nf-flow
# ✔ VPN：WireGuard / OpenVPN（tun）
# ✔ 科学上网：sing-box (passwall2)
# ✔ 内网扩展：EasyTier
# ✔ NAS能力：Samba4

# ❌ 已完全移除：
# - DAE / BPF增强链（无可编程数据面）
# - Quickfile-go（用户自行后装）
# - 所有 Xray / SSR / Shadowsocks 备用栈

