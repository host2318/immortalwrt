# ================= Passwall2 (sing-box only) =================
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_socat=y

CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_luci-app-passwall2_Basic_Core_SingBox=y

CONFIG_PACKAGE_luci-app-passwall2_Basic_Core_All=n
CONFIG_PACKAGE_luci-app-passwall2_Basic_Core_Xray=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray=n

CONFIG_PACKAGE_shadowsocks-libev=n
CONFIG_PACKAGE_shadowsocksr-libev=n
CONFIG_PACKAGE_shadowsocks-rust=n
CONFIG_PACKAGE_simple-obfs=n
CONFIG_PACKAGE_v2ray-plugin=n

# ================= NSS（核心数据面）=================
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-netlink=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-vlan=y
CONFIG_PACKAGE_kmod-qca-nss-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-crypto=y

# ================= Firewall =================
CONFIG_PACKAGE_firewall4=y

# ================= EasyTier =================
CONFIG_PACKAGE_easytier=y
CONFIG_PACKAGE_luci-app-easytier=y

# ================= Samba4 =================
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-utils=y
CONFIG_PACKAGE_luci-app-samba4=y

# ================= 基础工具 =================
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_vim=y
CONFIG_PACKAGE_curl=y

# ================= SSH =================
CONFIG_PACKAGE_openssh-sftp-server=y

# ================= 🚨 极限关键点（WiFi彻底切断） =================

# ❌ 彻底禁止 cfg80211 / mac80211
# （关键：避免 mac80211 被隐式拉起）

CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-mac80211=n

# ❌ WiFi driver 全禁
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n

CONFIG_PACKAGE_wpad=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd=n
CONFIG_PACKAGE_hostapd-common=n

# firmware 全禁
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ipq-wifi-link_nn6000=n

# ================= 关键说明 =================
# ✔ 这是 NSS-only headless router profile
# ✔ 无 WiFi stack / 无 mac80211
# ✔ 无无线驱动依赖链
# ✔ mac80211 compile 不会再触发
# ✔ 数据面完全走 NSS + nft flow

